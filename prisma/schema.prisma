generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CASHIER
  ADMIN
  AUDITOR
}

enum BusinessType {
  DESSERT_SHOP
  CAFE
  RESTAURANT
  RETAIL
  MINIMARKET
  SALON
  CUSTOM
}

enum Dimension {
  WEIGHT
  VOLUME
  COUNT
}

enum IngredientMovementType {
  ENTRY
  EXIT
  ADJUSTMENT
}

enum IngredientMovementReasonCode {
  PURCHASE
  INITIAL_LOAD
  SUPPLIER_RETURN
  POSITIVE_ADJUSTMENT
  WASTE
  DAMAGE
  INTERNAL_USE
  EXPIRATION
  NEGATIVE_ADJUSTMENT
  PHYSICAL_COUNT
  ADMIN_CORRECTION
}

enum IngredientMovementReferenceType {
  MANUAL
  SALE
}

enum VatType {
  ZERO
  EXEMPT
  FIVE
  NINETEEN
  NOT_APPLICABLE
}

enum TaxCategory {
  TAXED
  EXEMPT
  EXCLUDED
  NOT_SUBJECT
}

enum ProductType {
  SIMPLE
  VARIANT
}
enum SaleItemType {
  VARIANT
  COMBO
}

enum DiscountType {
  NONE
  PERCENT
  FIXED
}

enum SaleStatus {
  PENDING
  PAID
  VOID
}

enum PaymentMethod {
  CASH
  TRANSFER
}

enum BusinessActivityType {
  CASH_OPENED
  CASH_CLOSED
  SALE_COMPLETED
  STOCK_MOVEMENT
}

enum BusinessActivityEntityType {
  CASH_SESSION
  SALE
  INGREDIENT_MOVEMENT
}

model User {
  id                     Int                  @id @default(autoincrement())
  name                   String
  username               String               @unique
  email                  String               @unique
  passwordHash           String
  role                   UserRole
  themePreference        String               @default("midnight-indigo")
  ingredientMovements    IngredientMovement[]
  openedSessions         CashSession[]        @relation("OpenedSessions")
  closedSessions         CashSession[]        @relation("ClosedSessions")
  sales                  Sale[]
  auditLogs              AuditLog[]
  updatedBusinessConfigs BusinessConfig[]
}

model BusinessConfig {
  id           Int          @id @default(1)
  businessName String
  legalName    String?
  businessType BusinessType @default(DESSERT_SHOP)
  currencyCode String       @default("COP")
  timezone     String       @default("America/Bogota")
  countryCode  String       @default("CO")
  email        String?
  phone        String?
  address      String?
  modules      Json
  updatedById  Int?
  updatedBy    User?        @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Location {
  id           Int               @id @default(autoincrement())
  name         String            @unique
  stocks       IngredientStock[]
  movements    IngredientMovement[]
  cashSessions CashSession[]
  sales        Sale[]
}

model UnitType {
  id           Int        @id @default(autoincrement())
  code         String     @unique
  dimension    Dimension
  factorToBase Decimal
  ingredients  Ingredient[]
}

model Ingredient {
  id               Int                 @id @default(autoincrement())
  name             String              @unique
  dimension        Dimension
  defaultUnitCode  String
  defaultUnit      UnitType            @relation(fields: [defaultUnitCode], references: [code])
  stocks           IngredientStock[]
  movements        IngredientMovement[]
  variantRecipe    VariantRecipeItem[]
}

model IngredientStock {
  ingredientId   Int
  locationId     Int
  qtyOnHandBase  Decimal @default(0)
  ingredient     Ingredient   @relation(fields: [ingredientId], references: [id])
  location       Location     @relation(fields: [locationId], references: [id])

  @@id([ingredientId, locationId])
}

model IngredientMovement {
  id               Int                             @id @default(autoincrement())
  ingredientId     Int
  locationId       Int
  movementType     IngredientMovementType          @map("type")
  qtyBase          Decimal
  notes            String?                         @map("reason")
  referenceType    IngredientMovementReferenceType?
  referenceId      Int?                            @map("refSaleId")
  createdAt        DateTime                        @default(now())
  adjustedByUserId Int                             @map("userId")
  reasonCode       IngredientMovementReasonCode?
  supportDocument  String?
  unitCostAtTime   Decimal?
  batchNumber      String?
  previousStock    Decimal?
  newStock         Decimal?
  countedStock     Decimal?
  ingredient       Ingredient                      @relation(fields: [ingredientId], references: [id])
  location         Location                        @relation(fields: [locationId], references: [id])
  adjustedByUser   User                            @relation(fields: [adjustedByUserId], references: [id])
  sale             Sale?                           @relation(fields: [referenceId], references: [id])

  @@index([locationId, createdAt])
  @@index([ingredientId, createdAt])
  @@index([referenceType, referenceId])
}

model Product {
  id                Int              @id @default(autoincrement())
  name              String           @unique
  internalCode      String?          @unique
  barcode           String?          @unique
  supplierReference String?
  description       String?
  brand             String?
  imagePath         String?
  productType       ProductType      @default(SIMPLE)
  unspscCode        String?
  vatType           VatType?
  taxCategory       TaxCategory?
  unitMeasure       String?
  isService         Boolean          @default(false)
  applyInc          Boolean          @default(false)
  active            Boolean          @default(true)
  variants          ProductVariant[]
}

model ProductVariant {
  id           Int                 @id @default(autoincrement())
  productId    Int
  size         String
  sku          String              @unique
  salePrice    Decimal
  active       Boolean             @default(true)
  product      Product             @relation(fields: [productId], references: [id])
  recipeItems  VariantRecipeItem[]
  comboItems   ComboItem[]
}

model Combo {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  salePrice Decimal
  active    Boolean     @default(true)
  items     ComboItem[]
}

model ComboItem {
  id        Int            @id @default(autoincrement())
  comboId   Int
  variantId Int
  qty       Decimal
  combo     Combo          @relation(fields: [comboId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])
}

model VariantRecipeItem {
  variantId        Int
  ingredientId     Int
  qtyBaseRequired  Decimal
  variant          ProductVariant @relation(fields: [variantId], references: [id])
  ingredient       Ingredient     @relation(fields: [ingredientId], references: [id])

  @@id([variantId, ingredientId])
}

model CashSession {
  id                  Int       @id @default(autoincrement())
  locationId          Int
  openedBy            Int
  closedById          Int?
  openedAt            DateTime  @default(now())
  openingCash         Decimal
  closedAt            DateTime?
  closingCashExpected Decimal?
  closingCashCounted  Decimal?
  location            Location  @relation(fields: [locationId], references: [id])
  opener              User      @relation("OpenedSessions", fields: [openedBy], references: [id])
  closer              User?     @relation("ClosedSessions", fields: [closedById], references: [id])
  closureSnapshot     CashClosureSnapshot?
  sales               Sale[]
}

model CashClosureSnapshot {
  id                  Int       @id @default(autoincrement())
  cashSessionId       Int       @unique
  locationId          Int
  locationName        String
  openedById          Int
  openedByName        String
  closedById          Int
  closedByName        String
  openedAt            DateTime
  closedAt            DateTime
  openingCash         Decimal
  cashSalesTotal      Decimal
  transferSalesTotal  Decimal
  totalChangeGiven    Decimal
  closingCashExpected Decimal
  closingCashCounted  Decimal
  difference          Decimal
  summaryJson         Json?
  createdAt           DateTime  @default(now())
  cashSession         CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)

  @@index([closedAt])
  @@index([locationId, closedAt])
}

model BusinessActivity {
  id            Int                        @id @default(autoincrement())
  eventKey      String                     @unique
  type          BusinessActivityType
  entityType    BusinessActivityEntityType
  entityId      Int
  occurredAt    DateTime
  actorUserId   Int?
  actorUserName String?
  locationId    Int?
  locationName  String?
  title         String
  subtitle      String
  summaryJson   Json
  detailJson    Json
  createdAt     DateTime                   @default(now())

  @@index([occurredAt])
  @@index([type, occurredAt])
  @@index([entityType, entityId])
}

model Sale {
  id            Int           @id @default(autoincrement())
  locationId    Int
  cashierId     Int
  cashSessionId Int
  subtotal      Decimal
  discountType  DiscountType  @default(NONE)
  discountValue Decimal @default(0)
  discountAmount Decimal @default(0)
  total         Decimal
  status        SaleStatus    @default(PENDING)
  createdAt     DateTime      @default(now())
  location      Location      @relation(fields: [locationId], references: [id])
  cashier       User          @relation(fields: [cashierId], references: [id])
  cashSession   CashSession   @relation(fields: [cashSessionId], references: [id])
  items         SaleItem[]
  payments      Payment[]
  movements     IngredientMovement[]
}

model SaleItem {
  id         Int          @id @default(autoincrement())
  saleId     Int
  itemType   SaleItemType
  refId      Int
  qty        Decimal
  unitPrice  Decimal
  lineTotal  Decimal
  sale       Sale         @relation(fields: [saleId], references: [id])
}

model Payment {
  id             Int           @id @default(autoincrement())
  saleId          Int
  method          PaymentMethod
  amountReceived  Decimal
  amountApplied   Decimal
  changeGiven     Decimal
  sale            Sale         @relation(fields: [saleId], references: [id])
}

model AuditLog {
  id           Int       @id @default(autoincrement())
  userId       Int
  action       String
  entity       String
  entityId     Int?
  createdAt    DateTime  @default(now())
  metadataJson String
  user         User      @relation(fields: [userId], references: [id])
}




