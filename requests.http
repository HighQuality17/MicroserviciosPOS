@base = http://localhost:3000/api
@token = replace-with-jwt-token-only

# Nota: todos los endpoints siguientes, excepto /auth/login, / y /health,
# requieren:
# Authorization: Bearer {{token}}

### Login with admin user
POST {{base}}/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "replace-with-demo-password-only"
}

### Get current authenticated user
GET {{base}}/auth/me
Authorization: Bearer {{token}}

### Seed unit types
POST {{base}}/unit-types/seed

### Create location
POST {{base}}/locations
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "POS1"
}

### Create another location
POST {{base}}/locations
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "POS2"
}

### List available locations
GET {{base}}/locations
Authorization: Bearer {{token}}

### Create ingredient (coffee in grams)
POST {{base}}/ingredients
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Cafe Molido",
  "dimension": "WEIGHT",
  "default_unit_code": "g"
}

### List ingredients
GET {{base}}/ingredients
Authorization: Bearer {{token}}

### Adjust stock: +2kg coffee in POS1 (converted to 2000g base)
POST {{base}}/stock/adjust
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "location_id": 1,
  "ingredient_id": 1,
  "qty": 2,
  "unit_code": "kg",
  "reason": "Ingreso inicial",
  "user_id": 1
}

### Stock by location
GET {{base}}/stock?location_id=1
Authorization: Bearer {{token}}

### Create product
POST {{base}}/products
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Cafe Americano",
  "active": true
}

### List active products with variants
GET {{base}}/products
Authorization: Bearer {{token}}

### Update product
PATCH {{base}}/products/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Cafe Americano Clasico"
}

### Deactivate product
PATCH {{base}}/products/1/status
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "active": false
}

### Delete product if it has no variants or historical usage
DELETE {{base}}/products/1
Authorization: Bearer {{token}}

### Create variant 12oz
POST {{base}}/variants
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "product_id": 1,
  "size": "12oz",
  "sku": "CAF-AM-12",
  "sale_price": 7000
}

### Create variant 16oz
POST {{base}}/variants
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "product_id": 1,
  "size": "16oz",
  "sku": "CAF-AM-16",
  "sale_price": 9000
}

### List active variants
GET {{base}}/variants
Authorization: Bearer {{token}}

### Update variant
PATCH {{base}}/variants/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "size": "12oz Hot",
  "sku": "CAF-AM-12-HOT",
  "sale_price": 7500
}

### Deactivate variant
PATCH {{base}}/variants/1/status
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "active": false
}

### Delete variant if it has no historical usage or combo assignments
DELETE {{base}}/variants/1
Authorization: Bearer {{token}}

### Create combo
POST {{base}}/combos
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Combo Americano Doble",
  "sale_price": 15000,
  "active": true
}

### Set combo items
POST {{base}}/combos/1/items
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "items": [
    {
      "variant_id": 1,
      "qty": 1
    },
    {
      "variant_id": 2,
      "qty": 1
    }
  ]
}

### List active combos
GET {{base}}/combos
Authorization: Bearer {{token}}

### Preferred POS catalog endpoint
GET {{base}}/catalog
Authorization: Bearer {{token}}

### Admin summary metrics
GET {{base}}/admin/summary
Authorization: Bearer {{token}}

### Admin sales by payment method
GET {{base}}/admin/sales-by-payment
Authorization: Bearer {{token}}

### Admin top sold items
GET {{base}}/admin/top-items
Authorization: Bearer {{token}}

### Admin low stock
GET {{base}}/admin/low-stock
Authorization: Bearer {{token}}

### Admin recent activity
GET {{base}}/admin/recent-activity
Authorization: Bearer {{token}}

### Set recipe for variant 12oz: 18g coffee
POST {{base}}/recipes/variant/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "items": [
    {
      "ingredient_id": 1,
      "qty": 18,
      "unit_code": "g"
    }
  ]
}

### Set recipe for variant 16oz: 24g coffee
POST {{base}}/recipes/variant/2
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "items": [
    {
      "ingredient_id": 1,
      "qty": 24,
      "unit_code": "g"
    }
  ]
}

### Get recipe for variant 1
GET {{base}}/recipes/variant/1
Authorization: Bearer {{token}}

### Replace recipe for variant 1
PUT {{base}}/recipes/variant/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "items": [
    {
      "ingredient_id": 1,
      "qty": 20,
      "unit_code": "g"
    }
  ]
}

### Delete one recipe item from variant 1
DELETE {{base}}/recipes/variant/1/items/1
Authorization: Bearer {{token}}

### Open cash session
POST {{base}}/cash/open
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "location_id": 1,
  "opened_by": 1,
  "opening_cash": 50000
}

### Current cash session
GET {{base}}/cash/current?location_id=1
Authorization: Bearer {{token}}

### Create sale with 10% discount
POST {{base}}/sales
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "location_id": 1,
  "cashier_id": 1,
  "cash_session_id": 1,
  "discount_type": "PERCENT",
  "discount_value": 10,
  "items": [
    {
      "item_type": "VARIANT",
      "ref_id": 1,
      "qty": 2
    }
  ]
}

### Create sale with combo + variant
POST {{base}}/sales
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "location_id": 1,
  "cashier_id": 1,
  "cash_session_id": 1,
  "discount_type": "FIXED",
  "discount_value": 1000,
  "items": [
    {
      "item_type": "COMBO",
      "ref_id": 1,
      "qty": 1
    },
    {
      "item_type": "VARIANT",
      "ref_id": 1,
      "qty": 1
    }
  ]
}

### Pay sale in cash
POST {{base}}/sales/1/pay
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "method": "CASH",
  "amount_received": 20000,
  "user_id": 1
}

### Receipt
GET {{base}}/sales/1/receipt
Authorization: Bearer {{token}}

### Recent sales receipts summary
GET {{base}}/sales/recent?limit=5
Authorization: Bearer {{token}}

### Latest available sale / receipt
GET {{base}}/sales/latest
Authorization: Bearer {{token}}

### Close cash session
POST {{base}}/cash/close
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "cash_session_id": 1,
  "closed_by": 1,
  "closing_cash_counted": 62600
}

